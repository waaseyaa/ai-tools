{
    "name": "waaseyaa/ai-tools",
    "description": "Shared agent-tool catalogue (#[AsAgentTool] + AttributeToolRegistry) used by AgentExecutor and the MCP endpoint",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.5",
        "waaseyaa/access": "^0.1.0-alpha.267",
        "waaseyaa/entity": "^0.1.0-alpha.267",
        "waaseyaa/entity-storage": "^0.1.0-alpha.267",
        "waaseyaa/foundation": "^0.1.0-alpha.267"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "waaseyaa/testing": "^0.1.0-alpha.267"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\AI\\Tools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\AI\\Tools\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        },
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\AI\\Tools\\AiToolsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "repositories": [
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../testing"
        }
    ]
}
